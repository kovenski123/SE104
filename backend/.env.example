# ============ DATABASE ============
# Mặc định: SQLite (tự tạo file san_bong.db, không cần config)

# Để dùng MySQL: bỏ comment dòng dưới + sửa user/password/host
# DATABASE_URL=mysql+pymysql://root:123456@localhost:3306/san_bong

# Để dùng Azure SQL Database / SQL Server:
#   1. Cài Microsoft ODBC Driver 18: https://aka.ms/odbcdriver
#   2. Cài pyodbc: pip install pyodbc (đã có trong requirements.txt)
#   3. URL-encode password nếu có ký tự đặc biệt (@ → %40, ! → %21)
#   4. Mở firewall Azure: Portal → SQL Server → Networking → Add client IP
# DATABASE_URL=mssql+pyodbc://USER:PASSWORD@SERVER.database.windows.net:1433/san_bong?driver=ODBC+Driver+18+for+SQL+Server&Encrypt=yes&TrustServerCertificate=no
#
# Lưu ý khi setup MySQL (local):
#   CREATE DATABASE san_bong CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;
#   CREATE USER 'sanbong'@'localhost' IDENTIFIED BY 'your_password';
#   GRANT ALL PRIVILEGES ON san_bong.* TO 'sanbong'@'localhost';

# Hiện SQL log (debug):
# SQL_ECHO=true

# ============ SMTP (TUỲ CHỌN) ============
# Nếu để trống → reminder sẽ log ra console (không gửi mail thật)
# Gmail: 1) Bật 2FA  2) Tạo App Password  3) Copy file này thành .env

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-16-char-app-password
SMTP_FROM=Sân Bóng UIT <your-email@gmail.com>
