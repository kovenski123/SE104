# Cấu hình SMTP cho email reminder (TUỲ CHỌN)
# Nếu để trống → reminder sẽ log ra console terminal (không gửi mail thật)
# Để gửi mail thật qua Gmail:
#   1. Bật 2FA: https://myaccount.google.com/security
#   2. Tạo App Password: https://myaccount.google.com/apppasswords
#   3. Copy file này thành .env và điền vào dưới đây

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-16-char-app-password
SMTP_FROM=Sân Bóng UIT <your-email@gmail.com>
